	format(YCMDstr,90,"{FFFFFF}Фермеров: {FFEA06}%i\n",FarmStatPayS[idx][1]); strcat(string,YCMDstr);
	format(YCMDstr,90,"{FFFFFF}Собрано урожая: {FFEA06}%i\n",FarmStatPayS[idx][2]); strcat(string,YCMDstr);
