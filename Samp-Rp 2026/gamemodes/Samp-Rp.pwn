	GetPlayerFacingAngle(playerid, Angle);
	new intt = GetPlayerInterior(playerid);
	new vw = GetPlayerVirtualWorld(playerid);
	AdminVehicle[playerid][createdveh] = CreateVehicle(avehid, X,Y,Z, Angle, vcolor1, vcolor2, 60000);
