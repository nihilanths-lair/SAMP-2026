			mysql_format(DATABASE, QUERY, sizeof(QUERY), "%s WHERE `Name` = '%e'", QUERY, PTEMP[i][pName]);
			mysql_function_query(DATABASE, QUERY, false, "", "");
			printf("Файл-Аккаунт %s успешно сохранён", PTEMP[i][pName]);
			SaveMySQL(10,i);
			DeletePVar(i, "player_save");
