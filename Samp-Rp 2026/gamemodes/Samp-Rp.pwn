		if(sscanf(params, "ii",params[0x0],params[0x1]) || (params[0x0] == playerid && params[0x0] > -1)) return SCM(playerid, -1, " Введите: /cinvite [playerid (-1 для увольнения)] [слот (0 - 9)]");
