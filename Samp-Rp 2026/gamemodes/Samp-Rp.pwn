	new ip[15];
	GetPlayerIp(params[0],ip,15);
	format(YCMDstr, sizeof(YCMDstr), " Nik [%s]   R-IP [%s]   L-IP [%s]   IP [%s]",Name(params[0]),PTEMP[params[0]][pIpReg],PTEMP[params[0]][pvIp],ip);
	SCM(playerid,COLOR_BLUE,YCMDstr);
