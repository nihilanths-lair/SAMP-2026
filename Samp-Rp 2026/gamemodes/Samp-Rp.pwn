	format(YCMDstr,90," Механик: %s\n",WorkshopInfo[idx][wMechanic5]); strcat(str,YCMDstr);
	return ShowPlayerDialogEx(playerid,0,DIALOG_STYLE_MSGBOX, "Информ. об Автомастерской",str, "Скрыть", "");
}
