{
	if(PTEMP[playerid][pLogin] == 0) return true;
	if(PTEMP[playerid][pAdmin] < 5 || dostup[playerid] == 0) return true;
	if(paint_info[1] == 1) return SCM(playerid,COLOR_GREY," Пейнтболл уже запущен");
