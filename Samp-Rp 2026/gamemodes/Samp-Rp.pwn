			QUERY, PTEMP[i][pWeapons], PTEMP[i][pAmmos], PTEMP[i][pGunSkills], PTEMP[i][ptaxiexp], PTEMP[i][ptaxilvl], PTEMP[i][pTraining], PTEMP[i][pBoxSkill], PTEMP[i][pKongfuSkill], PTEMP[i][pKickboxSkill], PTEMP[i][pDLevel], PTEMP[i][pDExp]);

