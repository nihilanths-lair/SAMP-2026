{
	for(new bizz = 1; bizz <= TotalBizz; bizz++)
	{
		if(PlayerToPoint(5.0, playerid, BizzInfo[bizz][bEntranceX], BizzInfo[bizz][bEntranceY], BizzInfo[bizz][bEntranceZ]) && BizzInfo[bizz][bType] == 4)
