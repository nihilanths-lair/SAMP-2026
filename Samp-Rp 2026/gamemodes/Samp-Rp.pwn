	}
}

stock SendPoliceMessage(color, str[])
{
	foreach(i)
	{
		if(PTEMP[i][pLeader] == 1 || PTEMP[i][pMember] == 1 || PTEMP[i][pLeader] == 10 || PTEMP[i][pMember] == 10 || PTEMP[i][pLeader] == 21 || PTEMP[i][pMember] == 21) SCM(i, color, str);
	}
}
stock SendRadioMessage(member, color, str[])
{
	foreach(i)
	{
		if(PTEMP[i][pMember] == member || PTEMP[i][pLeader] == member) SCM(i, color, str);
