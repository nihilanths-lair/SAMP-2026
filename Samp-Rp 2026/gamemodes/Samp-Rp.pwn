	return true;
}
stock SendFamilyMessage(family, color, str[])
{
	foreach(i)
	{
		if(GetPVarInt(i,"Fraction_Duty"))
		{
			if(GetPVarInt(i,"chats") != 1)
			{
				if(PTEMP[i][pMember] == family || GetPVarInt(i,"Atisper") == family)
				{
					SCM(i, color, str);
				}
			}
		}
		else if(GetPVarInt(i,"Atisper") == family)
		{
			SCM(i, color, str);
		}
	}
}
