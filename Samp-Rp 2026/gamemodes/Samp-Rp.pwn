		switch(PTEMP[playerid][pMember])
		{
		case 3:
			{
				if(PTEMP[playerid][pRank] < 3)
				{
					SetPVarInt(playerid,"Fraction_Duty",1);
					SetPlayerSkin(playerid, PTEMP[playerid][pModel]);
