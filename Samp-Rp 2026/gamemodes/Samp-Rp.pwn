	SCM(playerid, 0x9b000ff, " Подсказка: А также любой таксист отвезет вас на работу бесплатно");
	SCM(playerid, -1, " Подсказка: Мы настоятельно рекомендуем вам прочесть \"Помощь\"");
	PlayerPlaySound(playerid, 1069, 0.0, 0.0, 0.0);
