stock WarningSP(playerid)
{
	if(GetPVarInt(playerid,"WarningCheat") < 1)
	{
		format(string,144," <Warning> %s[%d]: Возможно Car Spawn",PTEMP[playerid][pName],playerid);
		ABroadCast(COLOR_REDD,string,2);
