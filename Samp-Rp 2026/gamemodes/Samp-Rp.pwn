{
	new house = 0;
	for(new i = 1; i <= ALLKVARTIRI; i++)
	{
		if(strcmp(kvartinfo[i][vladelec],PTEMP[playerid][pName],false) == 0 && strcmp(kvartinfo[i][vladelec],"None",true) != 0) house++, PTEMP[playerid][pKvartiraKey] = i;
	}
	return house;
