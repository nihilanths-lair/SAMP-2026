			format(temp,sizeof(temp),"`bank_yakuza`= '%i',",MafiaBank[0][nYakuza]), 			strcat(QUERY,temp,sizeof(QUERY));
			format(temp,sizeof(temp),"`bank_rm`= '%i',",MafiaBank[0][nRm]), 					strcat(QUERY,temp,sizeof(QUERY));
